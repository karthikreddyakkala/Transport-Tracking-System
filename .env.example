# ============================================================
# TRANSPORT TRACKER - Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control
# ============================================================

# ------------------------------------------------------------
# DATABASE - NeonDB (PostgreSQL)
# ------------------------------------------------------------
# 1. Go to https://neon.tech and create a free account
# 2. Create a new project (e.g. "transport-tracker")
# 3. Copy the connection string from the Dashboard > Connection Details
#    Choose "Pooled connection" for DATABASE_URL
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# ------------------------------------------------------------
# AUTHENTICATION - Better-Auth
# ------------------------------------------------------------
# Generate a random secret: run `openssl rand -base64 32` in terminal
# This is used to sign session tokens - keep it secret!
BETTER_AUTH_SECRET=your-random-32-char-secret-here

# The base URL of your app (no trailing slash)
# Development: http://localhost:3000
# Production: https://your-domain.com
BETTER_AUTH_URL=http://localhost:3000

# ------------------------------------------------------------
# MAPS - Mapbox
# ------------------------------------------------------------
# 1. Go to https://mapbox.com and create a free account
# 2. Go to Account > Tokens > Create a token
# 3. Add scopes: styles:read, tiles:read
# Free tier: 50,000 map loads/month
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1Ijoixxxxxxxx

# Starting coordinates for your city (longitude, latitude)
# Find your city coordinates at https://www.latlong.net
NEXT_PUBLIC_MAP_CENTER_LNG=77.5946
NEXT_PUBLIC_MAP_CENTER_LAT=12.9716
NEXT_PUBLIC_MAP_ZOOM=13

# ------------------------------------------------------------
# REAL-TIME - Pusher
# ------------------------------------------------------------
# 1. Go to https://pusher.com and create a free account
# 2. Create a new app (Channels)
# 3. Go to App Keys to find these values
# Free tier: 200 concurrent connections, 200k messages/day
PUSHER_APP_ID=your-app-id
PUSHER_KEY=your-key
PUSHER_SECRET=your-secret
PUSHER_CLUSTER=ap2

# Public vars (used in browser)
NEXT_PUBLIC_PUSHER_KEY=your-key
NEXT_PUBLIC_PUSHER_CLUSTER=ap2

# ------------------------------------------------------------
# FILE UPLOAD - UploadThing
# ------------------------------------------------------------
# 1. Go to https://uploadthing.com and sign in with GitHub
# 2. Create a new app
# 3. Go to API Keys to find these values
# Free tier: 2GB storage
UPLOADTHING_TOKEN=your-uploadthing-token

# ------------------------------------------------------------
# AI - Google Gemini
# ------------------------------------------------------------
# 1. Go to https://aistudio.google.com
# 2. Click "Get API Key" > "Create API Key"
# 3. Copy the key
# Free tier: 15 requests/min, 1 million tokens/day
GEMINI_API_KEY=AIzaSy-your-gemini-api-key

# ------------------------------------------------------------
# GPS SIMULATOR - Upstash QStash
# ------------------------------------------------------------
# 1. Go to https://upstash.com and create a free account
# 2. Go to QStash > Dashboard
# 3. Copy all 4 values from the API Keys section
# Free tier: 500 messages/day
#
# QSTASH_URL: The regional endpoint shown in your QStash dashboard
#   e.g. https://qstash-eu-central-1.upstash.io  (Europe)
#        https://qstash-us-east-1.upstash.io      (US East)
QSTASH_URL=https://qstash-eu-central-1.upstash.io
QSTASH_TOKEN=your-qstash-token
QSTASH_CURRENT_SIGNING_KEY=sig_xxxx
QSTASH_NEXT_SIGNING_KEY=sig_xxxx

# The public URL of your deployed app (needed for QStash to call your simulator)
# LOCAL DEV: Keep as http://localhost:3000 — use the "Start Simulation" button in
#            the admin dashboard instead (no ngrok needed for local dev)
# PRODUCTION: Set this to your deployed domain e.g. https://your-app.vercel.app
#             Then click "Register QStash (prod)" in the admin dashboard once.
NEXT_PUBLIC_APP_URL=http://localhost:3000
